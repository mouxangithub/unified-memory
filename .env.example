# Unified Memory 环境配置示例
# 复制此文件为 .env 并填写实际值

# LLM 配置
LLM_BASE_URL=https://ollama.com/v1
LLM_MODEL=minimax-m2.7:cloud
# 可选: 其他模型如 xflite/astron-code-latest, xflite2/astron-code-latest, minimax/MiniMax-M2.7

# 嵌入模型配置
EMBED_MODEL=nomic-embed-text:latest
EMBED_BASE_URL=http://localhost:11434

# 数据库配置 (如果需要)
# DATABASE_URL=postgresql://user:password@localhost:5432/unified_memory

# 缓存配置
# REDIS_URL=redis://localhost:6379

# 外部 API 密钥 (如果需要)
# OPENAI_API_KEY=sk-...
# MINIMAX_API_KEY=...
# XUNFEI_API_KEY=...

# 日志级别
LOG_LEVEL=info
# 可选: debug, info, warn, error

# 服务器配置
PORT=3000
HOST=localhost

# 功能开关
ENABLE_WAL=true
ENABLE_EVIDENCE_CHAIN=true
ENABLE_AUTO_ORGANIZATION=true