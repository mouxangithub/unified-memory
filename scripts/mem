#!/usr/bin/env python3
"""
mem - 统一命令行入口 v3.0

所有记忆系统操作都通过这个入口。

新增功能:
- Context Tree 管理项目上下文
- 智能摘要压缩历史
- 项目模板快速启动
- 工作流验证

Usage:
    mem init --template software-project    # 用模板创建项目
    mem ctx update "任务" --progress 50      # 更新上下文
    mem ctx decision "标题" "内容"           # 记录决策
    mem summary compress --days 7            # 压缩日志
    mem validate                             # 验证工作流
"""

import sys
import argparse
from pathlib import Path
from datetime import datetime

sys.path.insert(0, str(Path(__file__).parent.parent))


# ============ 存储和搜索（支持降级） ============

def cmd_store(args):
    """存储记忆（支持降级）"""
    text = args.text
    tags = args.tags.split(",") if args.tags else []
    
    try:
        from agent_memory import AgentMemory
        memory = AgentMemory()
        memory.store(text, tags=tags)
        print(f"✅ 已存储: {text[:50]}...")
        return
    except:
        pass
    
    # 降级方案
    try:
        date = datetime.now().strftime("%Y-%m-%d")
        memory_dir = Path.home() / ".openclaw" / "workspace" / "memory"
        memory_dir.mkdir(parents=True, exist_ok=True)
        
        log_file = memory_dir / f"{date}.md"
        tags_str = f"[{', '.join(tags)}]" if tags else ""
        timestamp = datetime.now().strftime("%H:%M")
        
        with open(log_file, "a", encoding="utf-8") as f:
            f.write(f"- {timestamp} {tags_str} {text}\n")
        
        print(f"✅ 已存储: {text[:50]}... (文件模式)")
    except Exception as e:
        print(f"❌ 存储失败: {e}")


def cmd_search(args):
    """搜索记忆（支持降级）"""
    query = args.query
    limit = args.limit
    
    try:
        from resilience.error_fallback import ErrorFallback
        fallback = ErrorFallback()
        result = fallback.search_with_fallback(query, limit=limit)
        
        if result.success and result.data:
            print(f"\n🔍 搜索结果 ({result.level}):\n")
            for i, item in enumerate(result.data[:limit], 1):
                text = item.get("text", "")[:100]
                print(f"{i}. {text}...")
            return
    except:
        pass
    
    # 降级方案
    try:
        memory_dir = Path.home() / ".openclaw" / "workspace" / "memory"
        results = []
        
        for md_file in sorted(memory_dir.glob("*.md"), reverse=True):
            content = md_file.read_text()
            if query.lower() in content.lower():
                results.append({"file": md_file.name, "preview": content[:200]})
                if len(results) >= limit:
                    break
        
        if results:
            print(f"\n🔍 搜索结果 (文件模式):\n")
            for i, item in enumerate(results[:limit], 1):
                print(f"{i}. {item['file']}")
        else:
            print("❌ 无结果")
    except Exception as e:
        print(f"❌ 搜索失败: {e}")


# ============ Context Tree ============

def cmd_ctx(args):
    """项目上下文管理"""
    try:
        from context.context_tree import ContextTree
        ctx = ContextTree()
        
        if args.ctx_command == "init":
            ctx.init_project(args.name, args.desc or "")
            print(f"✅ 项目初始化: {args.name}")
        
        elif args.ctx_command == "update":
            ctx.update_current(args.task, args.progress, args.notes or "")
            print(f"✅ 状态更新: {args.task} ({args.progress}%)")
        
        elif args.ctx_command == "decision":
            tags = args.tags.split(",") if args.tags else []
            ctx.record_decision(args.title, args.content, tags)
            print(f"✅ 决策已记录: {args.title}")
        
        elif args.ctx_command == "status":
            current = ctx.get_current()
            print(f"📋 当前任务: {current['task']}")
            print(f"📊 进度: {current['progress']}%")
            print(f"📝 备注: {current['notes']}")
        
        elif args.ctx_command == "export":
            print(ctx.export_context())
    
    except Exception as e:
        print(f"❌ 操作失败: {e}")


# ============ 智能摘要 ============

def cmd_summary(args):
    """智能摘要"""
    try:
        from intelligence.smart_summarizer import SmartSummarizer
        summarizer = SmartSummarizer()
        
        if args.summary_command == "compress":
            summary = summarizer.compress_logs(args.days)
            print(summary[:500] + "...")
            print(f"\n✅ 压缩完成")
        
        elif args.summary_command == "decisions":
            decisions = summarizer.extract_decisions(args.days)
            print(f"📋 关键决策 (最近 {args.days} 天):\n")
            for i, decision in enumerate(decisions[:10], 1):
                print(f"{i}. {decision.get('content', '')[:80]}")
        
        elif args.summary_command == "summary":
            print(summarizer.generate_summary())
    
    except Exception as e:
        print(f"❌ 操作失败: {e}")


# ============ 项目模板 ============

def cmd_template(args):
    """项目模板"""
    try:
        from templates.project_templates import ProjectTemplate
        
        if args.template_command == "list":
            templates = ProjectTemplate.list_templates()
            print("📦 可用模板:\n")
            for name, info in templates.items():
                print(f"  {name}: {info['name']}")
                print(f"    {info['description']}\n")
        
        elif args.template_command == "create":
            template = ProjectTemplate(args.template_name)
            project_name = args.name or Path(args.path).name
            project_path = template.create(args.path, project_name, args.desc or "")
            print(f"✅ 项目创建成功: {project_path}")
    
    except Exception as e:
        print(f"❌ 操作失败: {e}")


# ============ 工作流验证 ============

def cmd_validate(args):
    """工作流验证"""
    try:
        from testing.workflow_validator import WorkflowValidator
        validator = WorkflowValidator()
        validator.validate_all()
    except Exception as e:
        print(f"❌ 验证失败: {e}")


# ============ 健康检查 ============

def cmd_health(args):
    """健康检查"""
    print("🏥 系统健康检查\n")
    
    issues = []
    
    # 向量库
    print("1️⃣ 向量库...", end=" ")
    try:
        import lancedb
        db_path = Path.home() / ".openclaw" / "workspace" / "memory" / "vector"
        if db_path.exists():
            db = lancedb.connect(db_path)
            tables = db.table_names()
            print(f"✅ ({len(tables)} 表)")
        else:
            print("⚠️ 未初始化")
    except Exception as e:
        print(f"❌ {e}")
        issues.append(str(e))
    
    # Ollama
    print("2️⃣ Ollama...", end=" ")
    try:
        import requests
        resp = requests.get("http://localhost:11434/api/tags", timeout=2)
        if resp.status_code == 200:
            models = resp.json().get("models", [])
            print(f"✅ ({len(models)} 模型)")
        else:
            print("⚠️ 连接失败")
    except:
        print("⚪ 未启动 (可选)")
    
    # Context Tree
    print("3️⃣ Context Tree...", end=" ")
    try:
        from context.context_tree import ContextTree
        print("✅")
    except:
        print("⚪ 未安装")
    
    # Smart Summarizer
    print("4️⃣ Smart Summarizer...", end=" ")
    try:
        from intelligence.smart_summarizer import SmartSummarizer
        print("✅")
    except:
        print("⚪ 未安装")
    
    print("\n" + "="*40)
    if issues:
        print("⚠️ 发现问题，运行 'mem fix' 修复")
    else:
        print("✅ 系统健康")


# ============ 主函数 ============

def main():
    parser = argparse.ArgumentParser(description="统一记忆系统 CLI v3.0")
    subparsers = parser.add_subparsers(dest="command")
    
    # store
    store_parser = subparsers.add_parser("store", help="存储记忆")
    store_parser.add_argument("text")
    store_parser.add_argument("--tags", "-t")
    
    # search
    search_parser = subparsers.add_parser("search", help="搜索记忆")
    search_parser.add_argument("query")
    search_parser.add_argument("--limit", "-l", type=int, default=10)
    
    # ctx (Context Tree)
    ctx_parser = subparsers.add_parser("ctx", help="项目上下文管理")
    ctx_subparsers = ctx_parser.add_subparsers(dest="ctx_command")
    
    ctx_init = ctx_subparsers.add_parser("init", help="初始化项目")
    ctx_init.add_argument("name")
    ctx_init.add_argument("--desc", "-d", default="")
    
    ctx_update = ctx_subparsers.add_parser("update", help="更新状态")
    ctx_update.add_argument("task")
    ctx_update.add_argument("--progress", "-p", type=int, default=0)
    ctx_update.add_argument("--notes", "-n", default="")
    
    ctx_decision = ctx_subparsers.add_parser("decision", help="记录决策")
    ctx_decision.add_argument("title")
    ctx_decision.add_argument("content")
    ctx_decision.add_argument("--tags", "-t", default="")
    
    ctx_subparsers.add_parser("status", help="查看状态")
    ctx_subparsers.add_parser("export", help="导出上下文")
    
    # summary
    summary_parser = subparsers.add_parser("summary", help="智能摘要")
    summary_subparsers = summary_parser.add_subparsers(dest="summary_command")
    
    compress_parser = summary_subparsers.add_parser("compress", help="压缩日志")
    compress_parser.add_argument("--days", "-d", type=int, default=7)
    
    decisions_parser = summary_subparsers.add_parser("decisions", help="提取决策")
    decisions_parser.add_argument("--days", "-d", type=int, default=30)
    
    summary_subparsers.add_parser("summary", help="生成摘要")
    
    # template
    template_parser = subparsers.add_parser("template", help="项目模板")
    template_subparsers = template_parser.add_subparsers(dest="template_command")
    
    template_subparsers.add_parser("list", help="列出模板")
    
    create_parser = template_subparsers.add_parser("create", help="创建项目")
    create_parser.add_argument("template_name")
    create_parser.add_argument("path")
    create_parser.add_argument("--name", "-n")
    create_parser.add_argument("--desc", "-d", default="")
    
    # validate
    subparsers.add_parser("validate", help="验证工作流")
    
    # health
    subparsers.add_parser("health", help="健康检查")
    
    args = parser.parse_args()
    
    commands = {
        "store": cmd_store,
        "search": cmd_search,
        "ctx": cmd_ctx,
        "summary": cmd_summary,
        "template": cmd_template,
        "validate": cmd_validate,
        "health": cmd_health,
    }
    
    if args.command in commands:
        commands[args.command](args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
