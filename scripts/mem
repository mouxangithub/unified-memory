#!/bin/bash
# Memory Quick Commands - 记忆系统快捷命令

SCRIPTS_DIR="$HOME/.openclaw/workspace/skills/unified-memory/scripts"

case "$1" in
  start)
    # 会话开始 - 加载上下文
    python3 "$SCRIPTS_DIR/memory_integration.py" session-start --context "${2:-当前任务}"
    ;;
  
  end)
    # 会话结束 - 存储记忆
    if [ -z "$2" ]; then
      echo "请提供对话内容"
      exit 1
    fi
    python3 "$SCRIPTS_DIR/memory_integration.py" session-end --conversation "$2"
    ;;
  
  heartbeat)
    # 心跳检查
    python3 "$SCRIPTS_DIR/memory_integration.py" heartbeat
    ;;
  
  store)
    # 快速存储
    python3 "$SCRIPTS_DIR/memory_agent.py" quick-store "$2"
    ;;
  
  load)
    # 加载上下文
    python3 "$SCRIPTS_DIR/memory_agent.py" load "${2:-}" --top-k ${3:-10}
    ;;
  
  remind)
    # 检查提醒
    python3 "$SCRIPTS_DIR/memory_reminder.py" check
    ;;
  
  health)
    # 健康报告
    python3 "$SCRIPTS_DIR/memory_health.py" report
    ;;
  
  webui)
    # 启动 Web UI
    python3 "$SCRIPTS_DIR/memory.py" webui --port ${2:-38080}
    ;;
  
  ask)
    # 智能问答
    python3 "$SCRIPTS_DIR/memory_qa.py" ask "$2"
    ;;
  
  graph)
    # 知识图谱
    python3 "$SCRIPTS_DIR/memory_graph.py" ${2:-build}
    ;;
  
  insights)
    # 智能洞察
    python3 "$SCRIPTS_DIR/memory_insights.py" ${2:-analyze}
    ;;
  
  backup)
    # 云备份
    python3 "$SCRIPTS_DIR/memory_cloud.py" backup
    ;;
  
  privacy)
    # 隐私扫描
    python3 "$SCRIPTS_DIR/memory_privacy.py" scan
    ;;
  
  recommend)
    # 智能推荐
    python3 "$SCRIPTS_DIR/memory_recommend.py" recommend --query "${2:-查询}" --k ${3:-5}
    ;;
  
  hot)
    # 热点记忆
    python3 "$SCRIPTS_DIR/memory_recommend.py" hot --k ${2:-5}
    ;;
  
  feedback)
    # 记忆反馈
    # mem feedback [memory_id] [helpful|irrelevant|wrong|outdated]
    python3 "$SCRIPTS_DIR/memory_adaptive.py" update --id "$2" --feedback "$3"
    ;;
  
  confidence)
    # 置信度统计
    python3 "$SCRIPTS_DIR/memory_adaptive.py" stats
    ;;
  
  audit)
    # 审计日志
    python3 "$SCRIPTS_DIR/memory_audit.py" query --limit ${2:-10}
    ;;
  
  report)
    # 合规报告
    python3 "$SCRIPTS_DIR/memory_audit.py" report --days ${2:-30}
    ;;
  
  sync)
    # 多Agent同步
    python3 "$SCRIPTS_DIR/memory_sync.py" sync
    ;;
  
  nodes)
    # 节点列表
    python3 "$SCRIPTS_DIR/memory_sync.py" list-nodes
    ;;
  
  summary)
    # 生成摘要
    python3 "$SCRIPTS_DIR/memory_summary.py" generate --id "$2" --style ${3:-medium}
    ;;
  
  inject)
    # 主动注入
    python3 "$SCRIPTS_DIR/memory_integration.py" proactive-inject --context "${2:-上下文}"
    ;;
  
  topic)
    # 主题检测
    python3 "$SCRIPTS_DIR/memory_integration.py" detect-topic --conversation "${2:-对话内容}"
    ;;
  
  *)
    echo "Memory Quick Commands v0.2.4"
    echo ""
    echo "Usage:"
    echo "  mem start [context]     # 会话开始，加载上下文"
    echo "  mem end \"对话内容\"     # 会话结束，存储记忆"
    echo "  mem heartbeat           # 心跳检查"
    echo "  mem store \"内容\"       # 快速存储"
    echo "  mem load [query] [k]    # 加载记忆"
    echo "  mem remind              # 检查提醒"
    echo "  mem health              # 健康报告"
    echo "  mem webui [port]        # 启动 Web UI"
    echo "  mem ask \"问题\"         # 智能问答"
    echo "  mem graph [cmd]         # 知识图谱"
    echo "  mem insights [cmd]      # 智能洞察"
    echo "  mem backup              # 云备份"
    echo "  mem privacy             # 隐私扫描"
    echo ""
    echo "  # 新增功能 v0.2.4:"
    echo "  mem recommend [query] [k] # 智能推荐"
    echo "  mem hot [k]               # 热点记忆"
    echo "  mem feedback [id] [type]  # 记忆反馈 (helpful/irrelevant/wrong)"
    echo "  mem confidence            # 置信度统计"
    echo "  mem audit [limit]         # 审计日志"
    echo "  mem report [days]         # 合规报告"
    echo "  mem sync                  # 多Agent同步"
    echo "  mem nodes                 # 节点列表"
    echo "  mem summary [id] [style]  # 生成摘要"
    echo "  mem inject [context]      # 主动上下文注入"
    echo "  mem topic [conversation]  # 主题检测"
    echo ""
    echo "Total features: 40+"
    ;;
esac
