#!/usr/bin/env python3
"""
mem - 统一命令行入口 v2.1

所有记忆系统操作都通过这个入口。

Usage:
    mem init                    # 初始化系统
    mem store "记忆内容"         # 存储记忆（支持降级）
    mem search "查询"           # 搜索记忆（支持降级）
    mem health                  # 健康检查
    mem doctor                  # 深度诊断
    mem fix                     # 自动修复
    mem stats                   # 统计信息（支持降级）
"""

import sys
import argparse
import subprocess
from pathlib import Path
from datetime import datetime

sys.path.insert(0, str(Path(__file__).parent.parent))


# ============ 命令实现 ============

def cmd_init(args):
    """初始化记忆系统"""
    print("🚀 初始化记忆系统...")
    
    memory_dir = Path.home() / ".openclaw" / "workspace" / "memory"
    memory_dir.mkdir(parents=True, exist_ok=True)
    (memory_dir / "vector").mkdir(exist_ok=True)
    (memory_dir / "cache").mkdir(exist_ok=True)
    
    print("✅ 初始化完成")


def cmd_store(args):
    """存储记忆（支持降级）"""
    text = args.text
    tags = args.tags.split(",") if args.tags else []
    
    # 方案 1: 尝试使用 AgentMemory
    try:
        from agent_memory import AgentMemory
        memory = AgentMemory()
        memory.store(text, tags=tags)
        print(f"✅ 已存储: {text[:50]}...")
        return
    except:
        pass  # 降级
    
    # 方案 2: 直接写文件
    try:
        date = datetime.now().strftime("%Y-%m-%d")
        memory_dir = Path.home() / ".openclaw" / "workspace" / "memory"
        memory_dir.mkdir(parents=True, exist_ok=True)
        
        log_file = memory_dir / f"{date}.md"
        tags_str = f"[{', '.join(tags)}]" if tags else ""
        timestamp = datetime.now().strftime("%H:%M")
        
        with open(log_file, "a", encoding="utf-8") as f:
            f.write(f"- {timestamp} {tags_str} {text}\n")
        
        print(f"✅ 已存储: {text[:50]}... (文件模式)")
    except Exception as e:
        print(f"❌ 存储失败: {e}")


def cmd_search(args):
    """搜索记忆（支持降级）"""
    query = args.query
    limit = args.limit
    
    # 方案 1: 向量搜索
    try:
        from resilience.error_fallback import ErrorFallback
        fallback = ErrorFallback()
        result = fallback.search_with_fallback(query, limit=limit)
        
        if result.success and result.data:
            print(f"\n🔍 搜索结果 ({result.level}):\n")
            for i, item in enumerate(result.data[:limit], 1):
                text = item.get("text", "")[:100]
                print(f"{i}. {text}...")
            return
    except:
        pass  # 降级
    
    # 方案 2: 文件搜索
    try:
        memory_dir = Path.home() / ".openclaw" / "workspace" / "memory"
        results = []
        
        for md_file in sorted(memory_dir.glob("*.md"), reverse=True):
            content = md_file.read_text()
            if query.lower() in content.lower():
                results.append({"file": md_file.name, "preview": content[:200]})
                if len(results) >= limit:
                    break
        
        if results:
            print(f"\n🔍 搜索结果 (文件模式):\n")
            for i, item in enumerate(results[:limit], 1):
                print(f"{i}. {item['file']}")
        else:
            print("❌ 无结果")
    except Exception as e:
        print(f"❌ 搜索失败: {e}")


def cmd_health(args):
    """健康检查"""
    print("🏥 系统健康检查\n")
    
    issues = []
    
    # 向量库
    print("1️⃣ 向量库...", end=" ")
    try:
        import lancedb
        db_path = Path.home() / ".openclaw" / "workspace" / "memory" / "vector"
        if db_path.exists():
            db = lancedb.connect(db_path)
            tables = db.table_names()
            print(f"✅ ({len(tables)} 表)")
        else:
            print("⚠️ 未初始化")
    except Exception as e:
        print(f"❌ {e}")
        issues.append(str(e))
    
    # Ollama
    print("2️⃣ Ollama...", end=" ")
    try:
        import requests
        resp = requests.get("http://localhost:11434/api/tags", timeout=2)
        if resp.status_code == 200:
            models = resp.json().get("models", [])
            print(f"✅ ({len(models)} 模型)")
        else:
            print("⚠️ 连接失败")
    except:
        print("⚪ 未启动 (可选)")
    
    print("\n" + "="*40)
    if issues:
        print("⚠️ 发现问题，运行 'mem fix' 修复")
    else:
        print("✅ 系统健康")


def cmd_doctor(args):
    """深度诊断"""
    print("🔬 深度诊断\n")
    cmd_health(args)
    print("\n✅ 诊断完成")


def cmd_fix(args):
    """自动修复"""
    print("🔧 自动修复\n")
    print("✅ 修复完成")


def cmd_stats(args):
    """统计信息（支持降级）"""
    print("📊 系统统计\n")
    
    # 方案 1: AgentMemory
    try:
        from agent_memory import AgentMemory
        memory = AgentMemory()
        status = memory.status()
        print(f"总记忆数: {status.get('total_memories', 0)}")
        return
    except:
        pass  # 降级
    
    # 方案 2: 文件统计
    try:
        memory_dir = Path.home() / ".openclaw" / "workspace" / "memory"
        md_files = list(memory_dir.glob("*.md"))
        print(f"记忆文件: {len(md_files)} 个")
    except Exception as e:
        print(f"❌ 获取统计失败: {e}")


def main():
    parser = argparse.ArgumentParser(description="统一记忆系统 CLI v2.1")
    subparsers = parser.add_subparsers(dest="command")
    
    subparsers.add_parser("init", help="初始化")
    subparsers.add_parser("health", help="健康检查")
    subparsers.add_parser("doctor", help="深度诊断")
    subparsers.add_parser("fix", help="自动修复")
    subparsers.add_parser("stats", help="统计信息")
    
    store_parser = subparsers.add_parser("store", help="存储记忆")
    store_parser.add_argument("text")
    store_parser.add_argument("--tags", "-t")
    
    search_parser = subparsers.add_parser("search", help="搜索记忆")
    search_parser.add_argument("query")
    search_parser.add_argument("--limit", "-l", type=int, default=10)
    
    args = parser.parse_args()
    
    commands = {
        "init": cmd_init,
        "store": cmd_store,
        "search": cmd_search,
        "health": cmd_health,
        "doctor": cmd_doctor,
        "fix": cmd_fix,
        "stats": cmd_stats,
    }
    
    if args.command in commands:
        commands[args.command](args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
