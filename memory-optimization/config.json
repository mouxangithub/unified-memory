{
  "workspacePath": "/root/.openclaw/workspace/memory",
  "unifiedMemoryPath": "/root/.openclaw/skills/unified-memory",
  "sync": {
    "enabled": true,
    "schedule": "0 2 * * *",
    "batchSize": 50,
    "dryRun": false
  },
  "dedup": {
    "similarityThreshold": 0.85,
    "exactMatchThreshold": 0.95,
    "cacheSize": 1000
  },
  "monitor": {
    "healthCheckInterval": 3600,
    "alertThreshold": 3
  },
  "api": {
    "port": 3851,
    "cacheSize": 100,
    "enableStats": true
  }
}