{
  "name": "unified-memory",
  "version": "5.2.4",
  "displayName": "Unified Memory",
  "displayNameZh": "统一记忆系统",
  "description": "🧠 Unified Memory v5.2.4 - Advanced memory management system with hybrid search (BM25 + Vector + RRF), atomic transactions, WAL protocol, evidence chain, and plugin system. Complete knowledge management with hierarchical information model, intent analysis, session management, and lifecycle management.",
  "descriptionZh": "统一记忆系统 v5.2.4 - 高级记忆管理系统，支持混合搜索（BM25 + 向量 + RRF）、原子事务、WAL协议、证据链和插件系统。完整的知识管理，包含分层信息模型、意图分析、会话管理和生命周期管理。",
  "author": {
    "name": "mouxangithub",
    "github": "https://github.com/mouxangithub"
  },
  "license": "MIT",
  "homepage": "https://github.com/mouxangithub/unified-memory",
  "repository": "https://github.com/mouxangithub/unified-memory",
  "tags": [
    "memory",
    "ai-agent",
    "vector-search",
    "bm25",
    "hybrid-search",
    "long-term-memory",
    "knowledge-management",
    "mcp",
    "openviking",
    "session-management",
    "intent-analysis",
    "hierarchical-retrieval"
  ],
  "categories": [
    "ai",
    "productivity",
    "memory"
  ],
  "keywords": [
    "记忆",
    "知识库",
    "向量搜索",
    "混合搜索",
    "长期记忆"
  ],
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "engines": {
    "node": ">=22.0.0",
    "openclaw": ">=2.7.0"
  },
  "installation": {
    "method": "openclaw skills install",
    "command": "openclaw skills install unified-memory",
    "alternative": "git clone https://github.com/mouxangithub/unified-memory.git && cd unified-memory && npm install",
    "script": "curl -fsSL https://raw.githubusercontent.com/mouxangithub/unified-memory/main/install.sh | bash",
    "verifyCommand": "node src/cli/index.js health"
  },
  "dependencies": {
    "required": {
      "node": ">=22.0.0"
    },
    "optional": {
      "ollama": ">=0.1.0"
    },
    "bundled": [
      "@node-rs/jieba",
      "zod"
    ]
  },
  "permissions": {
    "filesystem": {
      "read": ["~/.openclaw/workspace/memory/"],
      "write": ["~/.openclaw/workspace/memory/"]
    },
    "env": ["OLLAMA_HOST", "OLLAMA_EMBED_MODEL"]
  },
  "features": {
    "core": [
      "混合搜索 (BM25 + Vector + RRF)",
      "原子事务",
      "WAL 协议 (Write-Ahead Log)",
      "证据链机制",
      "自动组织",
      "插件系统",
      "多租户支持",
      "实时分析"
    ],
    "search": [
      "BM25 全文搜索",
      "向量相似度搜索",
      "混合搜索 (RRF 融合)",
      "查询理解",
      "最大边际相关性 (MMR)",
      "重排序"
    ],
    "storage": [
      "JSON 文件存储",
      "WAL 事务日志",
      "冷热数据分层",
      "自动去重",
      "版本控制",
      "备份恢复"
    ],
    "intelligence": [
      "噪声过滤",
      "意图路由",
      "自适应跳过",
      "反思学习",
      "偏好提取",
      "自动摘要"
    ]
  },
  "quickStart": {
    "store": "mcporter call unified-memory memory_store '{\"content\": \"Hello Unified Memory\", \"metadata\": {\"category\": \"test\"}}'",
    "search": "mcporter call unified-memory memory_search '{\"query\": \"hello\", \"limit\": 10}'",
    "list": "mcporter call unified-memory memory_list '{\"limit\": 20}'",
    "health": "mcporter call unified-memory memory_health '{}'"
  },
  "mcp": {
    "transport": "stdio",
    "command": "node",
    "args": ["src/index.js"]
  },
  "screenshots": [],
  "changelog": "https://github.com/mouxangithub/unified-memory/blob/main/CHANGELOG.md",
  "readme": "README.md",
  "skillFile": "SKILL.md"
}