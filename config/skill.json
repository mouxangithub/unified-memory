    "memory-management",
    "context-tree",
    "knowledge-graph",
    "plugin-system",
    "atomic-transactions",
    "semantic-search",
    "dream-memory"
  ],
  "categories": [
    "memory",
    "search",
    "database",
    "ai",
    "productivity"
  ],
  "tags": [
    "memory-management",
    "hybrid-search",
    "vector-database",
    "semantic-search",
    "bm25",
    "rrf",
    "plugin-architecture",
    "atomic-transactions",
    "context-tree",
    "knowledge-graph",
    "mcp-tools",
    "openclaw-skill"
  ],
  "engines": {
    "openclaw": ">=2.7.0",
    "node": ">=18.0.0"
  },
  "compatibility": {
    "openclaw": ">=2.7.0",
    "node": ">=18.0.0",
    "platforms": ["linux", "darwin", "win32"]
  },
  "installation": {
    "auto": true,
    "command": "openclaw skills install unified-memory",
    "verify_command": "mcporter call unified-memory memory_health '{}'",
    "quick_install_script": "curl -fsSL https://raw.githubusercontent.com/mouxangithub/unified-memory/main/install.sh | bash",
    "description": "自包含技能包，无需外部记忆插件。一键安装，自动配置。",
    "description_zh": "自包含技能包，无需外部记忆插件。一键安装，自动配置。",
    "requirements": [
      "Node.js >= 18.0.0",
      "OpenClaw >= 2.7.0",
      "512MB 可用内存",
      "100MB 可用磁盘空间"
    ]
  },
  "dependencies": {
    "required": {
      "node": ">=18.0.0"
    },
    "optional": {
      "ollama": ">=0.1.0",
      "mcporter": ">=2026.3.0",
      "node-llama-cpp": "^3.18.1"
    },
    "bundled": [
      "@node-rs/jieba",
      "zod"
    ]
  },
  "permissions": {
    "filesystem": {
      "read": ["~/.openclaw/workspace/memory/"],
      "write": ["~/.openclaw/workspace/memory/"]
    },
    "env": [
      "OLLAMA_HOST",
      "OLLAMA_EMBED_MODEL",
      "NODE_ENV",
      "DATABASE_PATH",
      "CACHE_ENABLED"
    ],
    "network": {
      "optional": ["ollama-api"]
    }
  },
  "features": {
    "search": {
      "bm25": {"enabled": true, "description": "BM25 关键词搜索"},
      "vector": {"enabled": true, "description": "向量语义搜索"},
      "hybrid": {"enabled": true, "description": "RRF 混合搜索融合"},
      "qmd": {"enabled": true, "description": "查询-记忆-文档 三角融合"},
      "mmr": {"enabled": true, "description": "最大边际相关性"},
      "rerank": {"enabled": true, "description": "重排优化"},
      "faceted": {"enabled": true, "description": "分面搜索"}
    },
    "storage": {
      "atomic_transactions": {"enabled": true, "description": "两阶段提交原子事务"},
      "wal": {"enabled": true, "description": "预写日志协议"},
      "auto_dedup": {"enabled": true, "description": "自动去重检查"},
      "incremental_backup": {"enabled": true, "description": "增量备份"},
      "point_in_time_recovery": {"enabled": true, "description": "时间点恢复"}
    },
    "intelligence": {
      "context_tree": {"enabled": true, "description": "上下文树管理"},
      "knowledge_graph": {"enabled": true, "description": "知识图谱构建"},
      "noise_filter": {"enabled": true, "description": "噪音过滤"},
      "intent_routing": {"enabled": true, "description": "意图路由"},
      "adaptive_decay": {"enabled": true, "description": "自适应遗忘"},
      "predictive_caching": {"enabled": true, "description": "预测缓存"},
      "reflection": {"enabled": true, "description": "反思机制"},
      "lesson_learning": {"enabled": true, "description": "教训学习"}
    },
    "system": {
      "plugin_system": {"enabled": true, "description": "热插拔插件系统"},
      "mcp_interface": {"enabled": true, "description": "标准 MCP 接口"},
      "health_monitoring": {"enabled": true, "description": "健康状态监控"},
      "performance_analytics": {"enabled": true, "description": "性能分析"},
      "workflow_engine": {"enabled": true, "description": "工作流引擎"}
    }
  },
  "mcp": {
    "transport": "stdio",
    "command": "node",
    "args": ["src/index.js"],
    "protocol_version": "2024-11-05",
    "tools": [
      "memory_store",
      "memory_search",
      "memory_recall",
      "memory_delete",
      "memory_update",
      "memory_get",
      "memory_stats",
      "memory_health",
      "memory_backup",
      "memory_restore",
      "memory_export",
      "memory_import",
      "memory_clear",
      "memory_dedupe",
      "memory_analyze",
      "memory_graph_query",
      "memory_context_tree"
    ],
    "capabilities": {
      "tools": {"list_changed": true},
      "resources": {"list_changed": true}
    }
  },
  "triggers": {
    "keywords": [
      "记忆", "记住", "回忆", "忘掉",
      "memory", "recall", "forget", "remember",
      "知识库", "知识图谱", "上下文",
      "knowledge-base", "knowledge-graph", "context",
      "unified memory", "hybrid search", "atomic transaction"
    ],
    "commands": [
      "/memory",
      "/unified-memory",
      "/search-memory",
      "/记忆",
      "/recall"
    ]
  },
  "quick_start": {
    "test": "mcporter call unified-memory memory_health '{}'",
    "store": "mcporter call unified-memory memory_store '{\"content\": \"Hello\", \"category\": \"general\"}'",
    "search": "mcporter call unified-memory memory_search '{\"query\": \"hello\"}'",
    "stats": "mcporter call unified-memory memory_stats '{}'"
  },
