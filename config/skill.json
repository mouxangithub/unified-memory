    "type": "git",
    "url": "https://github.com/mouxangithub/unified-memory.git"
  },
  "documentation": {
    "overview": "https://github.com/mouxangithub/unified-memory/README.md",
    "quickstart": "https://github.com/mouxangithub/unified-memory/docs/en/getting-started/quickstart.md",
    "api": "https://github.com/mouxangithub/unified-memory/docs/en/api/overview.md",
    "architecture": "https://github.com/mouxangithub/unified-memory/docs/en/architecture/overview.md"
  },
  "keywords": [
    "ai-agent",
    "memory",
    "long-term-memory",
    "hybrid-search",
    "vector-search",
    "bm25",
    "rrf",
    "mcp",
