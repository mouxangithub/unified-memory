{
  "name": "unified-memory",
  "version": "5.2.10",
  "description": "Unified Memory v5.2.10 - Advanced AI Agent memory system with hybrid search (BM25 + Vector + RRF), atomic transactions, context tree, knowledge graph, and plugin architecture. 5-10x faster search, 60% storage reduction.",
  "description_zh": "Unified Memory v5.2.10 - 高级 AI Agent 记忆系统，支持混合搜索（BM25 + 向量 + RRF）、原子事务、上下文树、知识图谱、插件架构。搜索速度提升5-10倍，存储减少60%。零依赖，完整对标 QMD/MetaGPT。",
  "short_description": "AI Agent 专用记忆系统，混合搜索 + 原子事务 + 插件架构",
  "short_description_zh": "AI Agent 专用记忆系统，混合搜索 + 原子事务 + 插件架构",
  "author": {
    "name": "OpenClaw Team",
    "email": "team@openclaw.ai",
    "url": "https://openclaw.ai"
  },
  "contributors": [
    "刘选权 <mouxan@163.com>",
    "OpenClaw Team <team@openclaw.ai>"
  ],
  "license": "MIT",
  "homepage": "https://github.com/mouxangithub/unified-memory",
