{
  "name": "unified-memory",
  "version": "5.1.0",
  "type": "module",
  "description": "🧠 Unified Memory v5.1.0 - 梦境记忆重构与性能优化 (7层目录结构，1760个记忆，5-10倍检索速度)",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "node --test src/**/*.test.js",
    "query": "node memory/.dreams/scripts/query.cjs",
    "stats": "node memory/.dreams/scripts/query.cjs stats",
    "enhance": "node memory/.dreams/scripts/enhance-tags.cjs"
  },
  "keywords": [
    "memory",
    "ai-memory",
    "long-term-memory",
    "dream-memory",
    "hybrid-search",
    "bm25",
    "vector-search",
    "lancedb",
    "scene-induction",
    "pipeline",
    "chinese-nlp",
    "dreams-system",
    "memory-optimization"
  ],
  "author": "OpenClaw",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@node-rs/jieba": "^2.0.1",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "mcporter": ">=2026.3.0",
    "node-llama-cpp": "^3.18.1"
  },
  "peerDependenciesMeta": {
    "mcporter": {
      "optional": true
    },
    "node-llama-cpp": {
      "optional": true
    }
  },
  "openclaw": {
    "skills": [
      "src/index.js"
    ],
    "hooks": {
      "before_prompt_build": "before_prompt_build",
      "agent_end": "agent_end"
    }
  }
}
