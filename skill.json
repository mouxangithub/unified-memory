{
    "name": "unified-memory",
    "version": "2.0.0",
    "description": "AI Agent Memory System - Node.js ESM with BM25 + Vector hybrid search, MCP tools, REST API, Web Dashboard, Workflow Engine, and LLM Provider. Self-contained storage (JSON), no external memory plugin required.",
    "author": "mouxangithub",
    "license": "MIT",
    "homepage": "https://github.com/mouxangithub/unified-memory",
    "keywords": [
        "ai-agent",
        "memory",
        "vector-search",
        "bm25",
        "hybrid-search",
        "mcp",
        "openclaws"
    ],
    "engines": {
        "node": ">=18.0.0",
        "openclaw": ">=2026.3.0"
    },
    "installation": {
        "auto": true,
        "description": "Self-contained skill. No external memory plugin required.",
        "verify": "node src/cli/index.js health"
    },
    "dependencies": {
        "required": {
            "node": ">=18.0.0"
        },
        "optional": {
            "ollama": ">=0.1.0"
        }
    },
    "permissions": {
        "filesystem": {
            "read": ["~/.openclaw/workspace/memory/"],
            "write": ["~/.openclaw/workspace/memory/"]
        },
        "env": ["OLLAMA_HOST", "OLLAMA_EMBED_MODEL"]
    },
    "scripts": {
        "start": "node src/cli/index.js",
        "server": "node src/api/server.js",
        "webui": "node src/webui/dashboard.js",
        "test": "node --check src/index.js && node src/cli/index.js health",
        "install": "bash scripts/install.sh"
    },
    "mcp": {
        "transport": "stdio",
        "command": "node",
        "args": ["src/index.js"]
    },
    "quick_start": {
        "install": "bash scripts/install.sh",
        "test": "node src/cli/index.js health",
        "first_memory": "node src/cli/index.js store 'Hello memory'",
        "search": "node src/cli/index.js search 'test'"
    },
    "triggers": {
        "keywords": ["记忆", "记住", "memory", "recall", "forget", "知识库"],
        "commands": ["/memory"]
    },
    "features": {
        "search": ["bm25", "vector", "hybrid", "qmd"],
        "storage": ["json_file", "auto_store", "manual", "backup"],
        "api": ["mcp", "rest"],
        "visualization": ["dashboard"],
        "agents": ["workflow", "sandbox", "code_generator", "push", "llm_provider"]
    },
    "complementary": {
        "description": "Works independently. Can optionally integrate with memory-lancedb-pro for enhanced vector search.",
        "integration": "Set OLLAMA_HOST to enable cloud sync and advanced features."
    }
}
